    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO profiles (\n  id,\n  employee_id,\n  first_name,\n  last_name,\n  job_title,\n  department_id,\n  role,\n  manager_id,\n  is_active,\n  last_sap_sync,\n  created_at,\n  auth_email\n)\nVALUES (\n  '{{ $json.id }}',\n  '{{ $json.employee_id }}',\n  '{{ $json.first_name || \"\" }}',\n  '{{ $json.last_name || \"\" }}',\n  '{{ $json.job_title || \"\" }}',\n  {{ $json.department_id ? \"'\" + $json.department_id + \"'\" : \"NULL\" }},\n  '{{ $json.role || \"employee\" }}',\n  {{ $json.manager_id ? \"'\" + $json.manager_id + \"'\" : \"NULL\" }},\n  {{ $json.is_active !== undefined ? $json.is_active : true }},\n  NOW(),\n  {{ $json.created_at ? \"'\" + $json.created_at + \"'\" : \"NOW()\" }},\n  {{ $json.auth_email ? \"'\" + $json.auth_email + \"'\" : \"NULL\" }}\n)\n\nON CONFLICT (id) DO UPDATE SET\n  employee_id = EXCLUDED.employee_id,\n  first_name = EXCLUDED.first_name,\n  last_name = EXCLUDED.last_name,\n  job_title = EXCLUDED.job_title,\n  department_id = EXCLUDED.department_id,\n  role = EXCLUDED.role,\n  manager_id = EXCLUDED.manager_id,\n  is_active = EXCLUDED.is_active,\n  last_sap_sync = NOW(),\n  auth_email = EXCLUDED.auth_email;",
        "options": {}
      },
