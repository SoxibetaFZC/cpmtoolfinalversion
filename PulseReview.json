    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n  m.id AS manager_id,\n  m.first_name || ' ' || m.last_name AS manager_name,\n  m.auth_email AS manager_email,\n\n  e.id AS employee_id,\n  e.first_name || ' ' || e.last_name AS employee_name\n\nFROM profiles e\n\n-- 👨‍💼 Get manager\nJOIN profiles m \n  ON m.id = e.manager_id\n\n-- 📊 Check review\nLEFT JOIN monthly_reviews mr \n  ON mr.employee_id = e.id\n  AND mr.manager_id = m.id\n  AND mr.cycle_id = 'ffffffff-ffff-ffff-ffff-ffffffffffff'\n  AND mr.is_draft = false\n\nWHERE e.is_active = true\n\n-- ❌ No review submitted\nAND mr.id IS NULL;",
        "options": {}
